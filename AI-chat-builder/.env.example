# Database
DATABASE_URL=postgresql://chatbuilder:chatbuilder123@postgres:5432/chatbuilder
POSTGRES_USER=chatbuilder
POSTGRES_PASSWORD=chatbuilder123
POSTGRES_DB=chatbuilder

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption (for API keys)
ENCRYPTION_KEY=your-encryption-key-32-bytes-change-this

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_MINUTE_AUTH=1000

# Environment
ENVIRONMENT=development
